{
  "name": "kioskos",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,vue,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "rebuild:node": "pnpm rebuild better-sqlite3 @serialport/bindings-cpp 2>/dev/null || true",
    "scan-devices": "pnpm run rebuild:node; tsx scripts/scan-devices.ts",
    "list-ports": "pnpm run rebuild:node; tsx scripts/list-ports.ts",
    "test:nv9": "pnpm run rebuild:node; tsx scripts/test-nv9.ts",
    "find-printers": "pnpm run rebuild:node; tsx scripts/find-printers.ts",
    "test:printer": "pnpm run rebuild:node; tsx scripts/test-printer.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
